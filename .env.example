GEMINI_API_KEY="your_api_key_here"

# Tavily Search (Agent 联网搜索能力)
TAVILY_API_KEY="your_tavily_key_here"

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="your_langsmith_key_here"

# Feishu main bot = Housekeeper (receives all messages + sends as housekeeper)
# Permissions needed: im:message, im:resource, im:chat (+ WebSocket long connection)
FEISHU_APP_ID="your_app_id"
FEISHU_APP_SECRET="your_app_secret"

# Independent bots (send-only, each needs im:message:send_v2 permission)
# No need for HOUSEKEEPER bot - main bot IS the housekeeper
FEISHU_BOT_SHOWRUNNER_APP_ID=""
FEISHU_BOT_SHOWRUNNER_APP_SECRET=""
FEISHU_BOT_WRITER_APP_ID=""
FEISHU_BOT_WRITER_APP_SECRET=""
FEISHU_BOT_DIRECTOR_APP_ID=""
FEISHU_BOT_DIRECTOR_APP_SECRET=""
FEISHU_BOT_ART_DESIGN_APP_ID=""
FEISHU_BOT_ART_DESIGN_APP_SECRET=""
FEISHU_BOT_VOICE_DESIGN_APP_ID=""
FEISHU_BOT_VOICE_DESIGN_APP_SECRET=""
FEISHU_BOT_STORYBOARD_APP_ID=""
FEISHU_BOT_STORYBOARD_APP_SECRET=""
